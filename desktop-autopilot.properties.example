# Desktop Autopilot configuration
profile=minimal
enabled=true

# Input strategy: auto (try native first, fall back to Robot), robot, or native
# native = CGEventPost on macOS / SendInput on Windows — events look hardware-level
# robot  = java.awt.Robot — software-tagged, simpler but detectable by some tools
input.mode=auto
interval.seconds=6
pixels=2
mode=horizontal
mouse.enabled=true

# Sends balanced arrow-key pairs to the currently focused app.
# Use this only when your editor or IDE is focused.
keyboard.enabled=false
keyboard.mode=horizontal

# Hardware keyboard jiggle: presses a random key at a random interval.
# Fires independently of the mouse cycle.
# Supported keys: F15, SPACE, SHIFT, UP, DOWN, LEFT, RIGHT
# F15 is the cleanest choice — it's a real key that does nothing visible in any app.
keyboard.jiggle.enabled=false
keyboard.jiggle.min.seconds=60
keyboard.jiggle.max.seconds=90
jiggle.keys=F15,SHIFT,UP,DOWN

# Smooth mouse movement: instead of teleporting, the cursor slides through 5
# intermediate positions over ~60 ms, making movement look natural on screen
# and to monitoring software that tracks cursor velocity.
mouse.smooth=false

# Periodic left-click at current cursor position. Fires independently of the
# mouse move cycle. Useful for keeping chat apps (Slack, Teams, Zoom) green.
mouse.click.enabled=false
mouse.click.min.seconds=120
mouse.click.max.seconds=300

# Human-pattern simulation: varies move interval ±20%, step size 50-150%, adds
# micro-jitter (±2px), and occasionally skips a tick (10% chance) to mimic
# natural mouse behaviour. Recommended with profile=stealth or keep-awake.
human.pattern=false

# Prevent display/system sleep using a platform wake lock.
# macOS: holds an IOPMAssertion (same as `caffeinate -d`).
# Windows: calls SetThreadExecutionState(ES_CONTINUOUS | ES_DISPLAY_REQUIRED).
prevent.sleep=false

# If true, autopilot moves only after no user mouse activity is detected.
idle.only=false
idle.seconds=60

# Optional schedule. Supports overnight ranges, for example 22:00 to 06:00.
schedule.enabled=false
schedule.start=09:00
schedule.end=18:00
schedule.weekdays.only=true

tray.enabled=true
log.moves=true
